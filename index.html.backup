<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AdQuench - Free Water, Smart Advertising Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #547792 0%, #1A3263 100%); }
        .gradient-text { background: linear-gradient(135deg, #547792 0%, #1A3263 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .card-hover { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
        .btn-primary { background: linear-gradient(135deg, #547792 0%, #1A3263 100%); transition: all 0.3s ease; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(84, 119, 146, 0.3); }
        .btn-secondary { border: 2px solid #547792; color: #547792; transition: all 0.3s ease; }
        .btn-secondary:hover { background: #547792; color: white; transform: translateY(-2px); }
        .nav-link { position: relative; }
        .nav-link::after { content: ''; position: absolute; width: 0; height: 2px; bottom: -4px; left: 0; background: linear-gradient(135deg, #547792 0%, #1A3263 100%); transition: width 0.3s ease; }
        .nav-link:hover::after { width: 100%; }
        .bottle-3d { width: 120px; height: 280px; position: relative; transform-style: preserve-3d; animation: rotateBottle 12s linear infinite; }
        @keyframes rotateBottle { 0% { transform: rotateY(0deg); } 100% { transform: rotateY(360deg); } }
        .bottle-body { width: 100%; height: 100%; background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(200,230,255,0.8)); border-radius: 20px 20px 40px 40px; border: 2px solid #e5e7eb; position: relative; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .bottle-cap { width: 50px; height: 25px; background: linear-gradient(135deg, #547792, #1A3263); border-radius: 10px 10px 0 0; position: absolute; top: -20px; left: 50%; transform: translateX(-50%); }
        .ad-label { position: absolute; width: 100%; height: 120px; background: linear-gradient(135deg, #FF6B6B, #4ECDC4); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 12px; text-align: center; top: 60px; }
        .section-padding { padding: 80px 0; }
        .input-field { transition: all 0.3s ease; }
        .input-field:focus { border-color: #547792; box-shadow: 0 0 0 3px rgba(84, 119, 146, 0.1); }
        .kiosk-card { transition: all 0.4s ease; }
        .kiosk-card:hover { transform: scale(1.03); box-shadow: 0 25px 50px rgba(0,0,0,0.15); }
        .counter { font-variant-numeric: tabular-nums; }
        .live-indicator { animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .map-pin { transition: all 0.3s ease; }
        .map-pin:hover { transform: scale(1.2); }
        .qr-code:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
        .testimonial-card { background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
        .feature-icon { width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="fixed w-full bg-white/95 backdrop-blur-sm shadow-sm z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 gradient-bg rounded-lg flex items-center justify-center">
                        <i class="fas fa-tint text-white text-xl"></i>
                    </div>
                    <span class="text-2xl font-bold gradient-text">AdQuench</span>
                </div>
                <div class="hidden md:flex items-center space-x-8">
                    <a href="#home" class="nav-link text-gray-700 font-medium hover:text-gray-900">Home</a>
                    <a href="#how-it-works" class="nav-link text-gray-700 font-medium hover:text-gray-900">How It Works</a>
                    <a href="#advertisers" class="nav-link text-gray-700 font-medium hover:text-gray-900">For Advertisers</a>
                    <a href="#bottles" class="nav-link text-gray-700 font-medium hover:text-gray-900">Products</a>
                    <a href="#contact" class="nav-link text-gray-700 font-medium hover:text-gray-900">Contact</a>
                    <button class="btn-primary text-white px-6 py-2.5 rounded-lg font-medium">Get Started</button>
                </div>
                <div class="md:hidden">
                    <button id="mobile-menu-btn" class="text-gray-700 text-2xl"><i class="fas fa-bars"></i></button>
                </div>
            </div>
        </div>
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
            <div class="px-6 py-4 space-y-3">
                <a href="#home" class="block text-gray-700 font-medium py-2">Home</a>
                <a href="#how-it-works" class="block text-gray-700 font-medium py-2">How It Works</a>
                <a href="#advertisers" class="block text-gray-700 font-medium py-2">For Advertisers</a>
                <a href="#bottles" class="block text-gray-700 font-medium py-2">Products</a>
                <a href="#contact" class="block text-gray-700 font-medium py-2">Contact</a>
                <button class="btn-primary text-white px-6 py-2.5 rounded-lg font-medium w-full">Get Started</button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="pt-24 min-h-screen flex items-center gradient-bg">
        <div class="container mx-auto px-6 py-20">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <div class="inline-block bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
                        <span class="text-white font-medium text-sm">Now Serving 50,000+ Daily Users</span>
                    </div>
                    <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 leading-tight">Free Water for Everyone,<br><span class="text-yellow-300">Smart Advertising</span> for Business</h1>
                    <p class="text-xl text-white/90 mb-8 leading-relaxed">AdQuench provides free, refreshing water through smart kiosks in high-traffic locations. Businesses reach thousands of customers while supporting community hydration.</p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-12">
                        <button class="bg-white text-gray-800 px-8 py-4 rounded-lg font-semibold hover:bg-gray-100 transition flex items-center justify-center gap-2"><i class="fas fa-map-marker-alt"></i> Find a Kiosk</button>
                        <button class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-gray-800 transition flex items-center justify-center gap-2"><i class="fas fa-bullhorn"></i> Advertise With Us</button>
                    </div>
                    <div class="grid grid-cols-3 gap-6">
                        <div class="text-center"><h3 class="text-4xl font-bold text-white">50K+</h3><p class="text-white/80">Daily Users</p></div>
                        <div class="text-center"><h3 class="text-4xl font-bold text-white">100+</h3><p class="text-white/80">Kiosk Locations</p></div>
                        <div class="text-center"><h3 class="text-4xl font-bold text-white">500+</h3><p class="text-white/80">Happy Advertisers</p></div>
                    </div>
                </div>
                <div class="relative">
                    <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
                        <div class="text-center">
                            <div class="w-32 h-32 gradient-bg rounded-full flex items-center justify-center mx-auto mb-6"><i class="fas fa-tint text-white text-6xl"></i></div>
                            <h3 class="text-3xl font-bold text-white mb-2">100% Free Water</h3>
                            <p class="text-white/80 mb-6">No payment required. Ever.</p>
                            <div class="flex flex-wrap justify-center gap-2">
                                <span class="bg-white/20 text-white px-3 py-1 rounded-full text-sm">Visit Greece</span>
                                <span class="bg-white/20 text-white px-3 py-1 rounded-full text-sm">Tesla</span>
                                <span class="bg-white/20 text-white px-3 py-1 rounded-full text-sm">Local Startups</span>
                            </div>
                        </div>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 shadow-xl">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center"><i class="fas fa-check text-green-600 text-xl"></i></div>
                            <div><p class="font-semibold text-gray-800">Zero Cost</p><p class="text-sm text-gray-600">Fully funded by advertisers</p></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="section-padding bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Simple Process</span>
                <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">How AdQuench Works</h2>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">Our innovative platform connects thirsty consumers with businesses through smart water kiosks</p>
            </div>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="card-hover bg-gray-50 rounded-2xl p-8 text-center">
                    <div class="feature-icon gradient-bg text-white mx-auto mb-6"><i class="fas fa-map-marker-alt"></i></div>
                    <h3 class="text-2xl font-bold text-gray-800 mb-4">1. Find a Kiosk</h3>
                    <p class="text-gray-600 leading-relaxed">Locate our smart water kiosks in high-traffic areas like malls, train stations, universities, and public spaces.</p>
                </div>
                <div class="card-hover bg-gray-50 rounded-2xl p-8 text-center">
                    <div class="feature-icon gradient-bg text-white mx-auto mb-6"><i class="fas fa-mobile-alt"></i></div>
                    <h3 class="text-2xl font-bold text-gray-800 mb-4">2. Scan & Dispense</h3>
                    <p class="text-gray-600 leading-relaxed">Simply scan the QR code with your phone and receive your free water in an eco-friendly bottle with brand advertisements.</p>
                </div>
                <div class="card-hover bg-gray-50 rounded-2xl p-8 text-center">
                    <div class="feature-icon gradient-bg text-white mx-auto mb-6"><i class="fas fa-bullhorn"></i></div>
                    <h3 class="text-2xl font-bold text-gray-800 mb-4">3. Discover Brands</h3>
                    <p class="text-gray-600 leading-relaxed">Get introduced to amazing local businesses, startups, and established brands while staying hydrated.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- For Advertisers -->
    <section id="advertisers" class="section-padding bg-gray-50">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">For Businesses</span>
                <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">Advertise With AdQuench</h2>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">Reach thousands of engaged customers through our innovative advertising platform</p>
            </div>
            <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
                <div class="space-y-8">
                    <div class="flex items-start gap-4">
                        <div class="feature-icon gradient-bg text-white flex-shrink-0"><i class="fas fa-users"></i></div>
                        <div><h3 class="text-xl font-bold text-gray-800 mb-2">Targeted Audience</h3><p class="text-gray-600">Reach active consumers in high-traffic locations who are receptive to discovering new brands and services.</p></div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="feature-icon gradient-bg text-white flex-shrink-0"><i class="fas fa-dollar-sign"></i></div>
                        <div><h3 class="text-xl font-bold text-gray-800 mb-2">Cost-Effective Marketing</h3><p class="text-gray-600">Affordable advertising solutions perfect for startups, small businesses, and individual brands looking to maximize ROI.</p></div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="feature-icon gradient-bg text-white flex-shrink-0"><i class="fas fa-chart-line"></i></div>
                        <div><h3 class="text-xl font-bold text-gray-800 mb-2">Measurable Results</h3><p class="text-gray-600">Track your campaign performance with real-time analytics, customer engagement data, and conversion metrics.</p></div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="feature-icon gradient-bg text-white flex-shrink-0"><i class="fas fa-leaf"></i></div>
                        <div><h3 class="text-xl font-bold text-gray-800 mb-2">Eco-Friendly Brand Image</h3><p class="text-gray-600">Associate your brand with sustainability and community wellness. Show customers you care about the environment.</p></div>
                    </div>
                </div>
                <div class="bg-white rounded-2xl shadow-xl p-8">
                    <h3 class="text-2xl font-bold text-gray-800 mb-6">Advertising Packages</h3>
                    <div class="space-y-4">
                        <div class="border border-gray-200 rounded-xl p-4 hover:border-blue-500 transition cursor-pointer">
                            <div class="flex justify-between items-center mb-2"><h4 class="font-semibold text-gray-800">Bottle Advertising</h4><span class="text-blue-600 font-bold">From $50/month</span></div>
                            <p class="text-gray-600 text-sm">Your brand on eco-friendly water bottles distributed at kiosks</p>
                        </div>
                        <div class="border border-gray-200 rounded-xl p-4 hover:border-blue-500 transition cursor-pointer">
                            <div class="flex justify-between items-center mb-2"><h4 class="font-semibold text-gray-800">Kiosk Display</h4><span class="text-blue-600 font-bold">From $200/month</span></div>
                            <p class="text-gray-600 text-sm">Digital screens and physical branding on high-traffic kiosks</p>
                        </div>
                        <div class="border border-gray-200 rounded-xl p-4 hover:border-blue-500 transition cursor-pointer">
                            <div class="flex justify-between items-center mb-2"><h4 class="font-semibold text-gray-800">QR Code Campaigns</h4><span class="text-blue-600 font-bold">From $100/month</span></div>
                            <p class="text-gray-600 text-sm">Direct customer engagement through interactive QR code experiences</p>
                        </div>
                        <div class="border-2 border-blue-500 rounded-xl p-4 bg-blue-50 cursor-pointer">
                            <div class="flex justify-between items-center mb-2"><h4 class="font-semibold text-gray-800">Premium Package</h4><span class="text-blue-600 font-bold">From $500/month</span></div>
                            <p class="text-gray-600 text-sm">All advertising channels + advanced analytics + dedicated support</p>
                        </div>
                    </div>
                    <button class="w-full mt-6 btn-primary text-white py-3 rounded-lg font-semibold">Start Advertising Today</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Bottle Showcase -->
    <section id="bottles" class="section-padding gradient-bg">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-white/80 font-semibold text-sm uppercase tracking-wide">Products</span>
                <h2 class="text-4xl font-bold text-white mt-2 mb-4">Our Bottle Collection</h2>
                <p class="text-xl text-white/90 max-w-3xl mx-auto">Three sizes to match your advertising needs and customer preferences</p>
            </div>
            <div class="text-center mb-12">
                <img src="https://images.unsplash.com/photo-1602143407151-7111542de6e8?w=800&q=80" alt="Water bottles with brand advertisements" class="rounded-2xl shadow-2xl mx-auto max-w-2xl w-full mb-6" onerror="this.style.display='none'">
                <p class="text-white/80 text-lg">Real examples of branded water bottles at our kiosks</p>
            </div>
            <div class="grid md:grid-cols-3 gap-8 justify-items-center">
                <div class="text-center">
                    <div class="bottle-3d" style="width: 100px; height: 220px;">
                        <div class="bottle-cap"></div>
                        <div class="bottle-body"><div class="ad-label" style="top: 50px; height: 80px; font-size: 10px;"><span>Your Brand</span></div></div>
                    </div>
                    <h3 class="text-2xl font-bold text-white mt-8">Small</h3>
                    <p class="text-white/80 mb-2">250ml - Perfect for quick refreshment</p>
                    <div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 inline-block"><span class="text-white font-semibold">$30/month</span></div>
                </div>
                <div class="text-center">
                    <div class="bottle-3d" style="width: 120px; height: 280px;">
                        <div class="bottle-cap"></div>
                        <div class="bottle-body"><div class="ad-label" style="top: 60px;"><span>Your Brand</span></div></div>
                    </div>
                    <h3 class="text-2xl font-bold text-white mt-8">Medium</h3>
                    <p class="text-white/80 mb-2">500ml - Most popular choice</p>
                    <div class="bg-white rounded-full px-4 py-2 inline-block"><span class="gradient-text font-semibold">$50/month</span></div>
                </div>
                <div class="text-center">
                    <div class="bottle-3d" style="width: 140px; height: 320px;">
                        <div class="bottle-cap" style="width: 60px;"></div>
                        <div class="bottle-body"><div class="ad-label" style="top: 80px; height: 140px;"><span style="font-size: 14px;">Your Logo & Message</span></div></div>
                    </div>
                    <h3 class="text-2xl font-bold text-white mt-8">Large</h3>
                    <p class="text-white/80 mb-2">750ml - Maximum brand visibility</p>
                    <div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 inline-block"><span class="text-white font-semibold">$80/month</span></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Live Dashboard Section -->
    <section class="section-padding bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Live Dashboard</span>
                <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">AdQuench in Action</h2>
                <p class="text-xl text-gray-600">Real-time statistics from our network</p>
            </div>
            <div class="grid md:grid-cols-4 gap-6 mb-12">
                <div class="stat-card card-hover">
                    <div class="flex items-center justify-center mb-4">
                        <div class="w-3 h-3 bg-green-500 rounded-full live-indicator mr-2"></div>
                        <span class="text-sm text-gray-500">Live</span>
                    </div>
                    <h3 class="text-4xl font-bold gradient-text counter" data-target="52347">52,347</h3>
                    <p class="text-gray-600">Waters Dispensed Today</p>
                </div>
                <div class="stat-card card-hover">
                    <div class="flex items-center justify-center mb-4">
                        <div class="w-3 h-3 bg-blue-500 rounded-full live-indicator mr-2" style="animation-delay: 0.5s;"></div>
                        <span class="text-sm text-gray-500">Active</span>
                    </div>
                    <h3 class="text-4xl font-bold gradient-text">127</h3>
                    <p class="text-gray-600">Kiosks Online</p>
                </div>
                <div class="stat-card card-hover">
                    <div class="flex items-center justify-center mb-4">
                        <div class="w-3 h-3 bg-purple-500 rounded-full live-indicator mr-2" style="animation-delay: 1s;"></div>
                        <span class="text-sm text-gray-500">Growing</span>
                    </div>
                    <h3 class="text-4xl font-bold gradient-text">847</h3>
                    <p class="text-gray-600">Active Advertisers</p>
                </div>
                <div class="stat-card card-hover">
                    <div class="flex items-center justify-center mb-4">
                        <div class="w-3 h-3 bg-yellow-500 rounded-full live-indicator mr-2" style="animation-delay: 1.5s;"></div>
                        <span class="text-sm text-gray-500">Popular</span>
                    </div>
                    <h3 class="text-4xl font-bold gradient-text">98%</h3>
                    <p class="text-gray-600">Customer Satisfaction</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Kiosk Locations Section -->
    <section class="section-padding bg-gray-50">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Locations</span>
                <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">Find a Kiosk Near You</h2>
                <p class="text-xl text-gray-600">Interactive map showing all AdQuench kiosk locations</p>
            </div>
            <div class="grid md:grid-cols-2 gap-8 mb-12">
                <div class="kiosk-card bg-white rounded-2xl shadow-xl overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80" alt="Shopping Mall Kiosk" class="w-full h-48 object-cover">
                    <div class="p-6">
                        <div class="flex items-center gap-2 mb-3">
                            <i class="fas fa-shopping-bag text-blue-600"></i>
                            <h3 class="text-xl font-bold text-gray-800">Shopping Mall Kiosk</h3>
                        </div>
                        <p class="text-gray-600 mb-4">High-traffic location with 5,000+ daily visitors. Perfect for retail and consumer brands.</p>
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-500"><i class="fas fa-map-marker-alt mr-1"></i> 25+ Locations</span>
                            <button class="text-blue-600 font-semibold hover:underline">View Details</button>
                        </div>
                    </div>
                </div>
                <div class="kiosk-card bg-white rounded-2xl shadow-xl overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1565626424178-c699f6601afd?w=600&q=80" alt="Train Station Kiosk" class="w-full h-48 object-cover">
                    <div class="p-6">
                        <div class="flex items-center gap-2 mb-3">
                            <i class="fas fa-train text-blue-600"></i>
                            <h3 class="text-xl font-bold text-gray-800">Train Station Kiosk</h3>
                        </div>
                        <p class="text-gray-600 mb-4">Commuter hotspot with 8,000+ daily users. Ideal for transportation and travel advertisements.</p>
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-500"><i class="fas fa-map-marker-alt mr-1"></i> 30+ Locations</span>
                            <button class="text-blue-600 font-semibold hover:underline">View Details</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center">
                <button class="btn-primary text-white px-8 py-4 rounded-lg font-semibold">
                    <i class="fas fa-map-marked-alt mr-2"></i> View All Locations
                </button>
            </div>
        </div>
    </section>

    <!-- QR Code Experience Section -->
    <section class="section-padding bg-white">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Technology</span>
                    <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">Scan. Drink. Discover.</h2>
                    <p class="text-xl text-gray-600 mb-8">Our smart QR code system connects thirsty customers with your brand in seconds.</p>
                    <div class="space-y-4">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-qrcode text-blue-600 text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800">Instant Scan</h4>
                                <p class="text-gray-600">Customers scan QR code with any smartphone camera</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-glass-water text-green-600 text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800">Free Water Dispensed</h4>
                                <p class="text-gray-600">Eco-friendly bottle with your branded label</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-chart-line text-purple-600 text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800">Track Engagement</h4>
                                <p class="text-gray-600">Real-time analytics on scans, clicks, and conversions</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center">
                    <div class="qr-code bg-white p-8 rounded-2xl shadow-2xl inline-block transition-all duration-300">
                        <div class="w-64 h-64 bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl flex items-center justify-center mb-4">
                            <div class="text-center">
                                <i class="fas fa-qrcode text-8xl text-gray-800 mb-2"></i>
                                <p class="text-sm text-gray-500">Scan for free water</p>
                            </div>
                        </div>
                        <p class="text-gray-600 font-medium">Try it yourself!</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="section-padding bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Testimonials</span>
                <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">What Our Users Say</h2>
                <p class="text-xl text-gray-600">Real experiences from our community</p>
            </div>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="testimonial-card card-hover">
                    <div class="flex items-center mb-4">
                        <img src="https://images.unsplash.com/photo-1494790108755-2616b612b786?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80" alt="Sarah Johnson" class="w-14 h-14 rounded-full object-cover mr-4">
                        <div><h4 class="font-bold text-gray-800">Sarah Johnson</h4><p class="text-gray-600 text-sm">Daily User</p></div>
                    </div>
                    <div class="flex mb-3">
                        <i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i>
                    </div>
                    <p class="text-gray-600 leading-relaxed">"AdQuench is a lifesaver! Free water at the mall while discovering new local brands. The concept is absolutely genius!"</p>
                </div>
                <div class="testimonial-card card-hover">
                    <div class="flex items-center mb-4">
                        <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80" alt="Mike Chen" class="w-14 h-14 rounded-full object-cover mr-4">
                        <div><h4 class="font-bold text-gray-800">Mike Chen</h4><p class="text-gray-600 text-sm">Startup Founder</p></div>
                    </div>
                    <div class="flex mb-3">
                        <i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i>
                    </div>
                    <p class="text-gray-600 leading-relaxed">"Best marketing investment we made! Reached 10,000+ customers in just one month. The ROI has been incredible."</p>
                </div>
                <div class="testimonial-card card-hover">
                    <div class="flex items-center mb-4">
                        <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80" alt="Emma Davis" class="w-14 h-14 rounded-full object-cover mr-4">
                        <div><h4 class="font-bold text-gray-800">Emma Davis</h4><p class="text-gray-600 text-sm">Student</p></div>
                    </div>
                    <div class="flex mb-3">
                        <i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i><i class="fas fa-star text-yellow-400"></i>
                    </div>
                    <p class="text-gray-600 leading-relaxed">"Perfect for students! I stay hydrated between classes and find awesome local businesses. Love this initiative!"</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section-padding bg-gray-50">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-wide">Contact</span>
                <h2 class="text-4xl font-bold text-gray-800 mt-2 mb-4">Get In Touch</h2>
                <p class="text-xl text-gray-600">Ready to quench your thirst or grow your business?</p>
            </div>
            <div class="max-w-4xl mx-auto mb-12 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-8">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-info-circle text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">Why Contact Us?</h3>
                        <p class="text-gray-600 mb-3"><strong>For Customers:</strong> Report issues with kiosks, suggest new locations, share feedback about water quality, or inquire about partnership opportunities for your venue.</p>
                        <p class="text-gray-600"><strong>For Advertisers:</strong> Get custom quotes, schedule a demo, discuss bulk advertising packages, or learn about our analytics dashboard and ROI tracking tools.</p>
                    </div>
                </div>
            </div>
            <div class="grid md:grid-cols-2 gap-12 max-w-6xl mx-auto">
                <div class="bg-white rounded-2xl shadow-xl p-8">
                    <h3 class="text-2xl font-bold text-gray-800 mb-6">For Customers</h3>
                    <form id="customerForm" class="space-y-4">
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label><input type="text" name="name" required class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Enter your name"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label><input type="email" name="email" required class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Enter your email"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Message</label><textarea name="message" required rows="4" class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Tell us about your experience..."></textarea></div>
                        <button type="submit" class="w-full btn-primary text-white py-3 rounded-lg font-semibold">Send Message</button>
                    </form>
                </div>
                <div class="bg-white rounded-2xl shadow-xl p-8">
                    <h3 class="text-2xl font-bold text-gray-800 mb-6">For Advertisers</h3>
                    <form id="advertiserForm" class="space-y-4">
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Company Name</label><input type="text" name="company" required class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Enter company name"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Business Email</label><input type="email" name="email" required class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Enter business email"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label><input type="tel" name="phone" class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Enter phone number"></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Advertising Package</label><select name="package" required class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none"><option value="">Select a package</option><option value="small">Small Bottle - $30/month</option><option value="medium">Medium Bottle - $50/month</option><option value="large">Large Bottle - $80/month</option><option value="bottle">Bottle Advertising - $50/month</option><option value="kiosk">Kiosk Display - $200/month</option><option value="qr">QR Code Campaigns - $100/month</option><option value="premium">Premium Package - $500/month</option></select></div>
                        <div><label class="block text-sm font-medium text-gray-700 mb-1">Message</label><textarea name="message" rows="3" class="input-field w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none" placeholder="Tell us about your advertising goals..."></textarea></div>
                        <button type="submit" class="w-full btn-primary text-white py-3 rounded-lg font-semibold">Start Advertising</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-16">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-4 gap-8 mb-12">
                <div>
                    <div class="flex items-center space-x-3 mb-4">
                        <div class="w-10 h-10 gradient-bg rounded-lg flex items-center justify-center"><i class="fas fa-tint text-white text-xl"></i></div>
                        <span class="text-2xl font-bold">AdQuench</span>
                    </div>
                    <p class="text-gray-400 leading-relaxed">Providing free water to communities while helping businesses reach their target audience.</p>
                </div>
                <div>
                    <h4 class="font-bold text-lg mb-4">Quick Links</h4>
                    <ul class="space-y-2">
                        <li><a href="#home" class="text-gray-400 hover:text-white transition">Home</a></li>
                        <li><a href="#how-it-works" class="text-gray-400 hover:text-white transition">How It Works</a></li>
                        <li><a href="#advertisers" class="text-gray-400 hover:text-white transition">For Advertisers</a></li>
                        <li><a href="#bottles" class="text-gray-400 hover:text-white transition">Products</a></li>
                        <li><a href="#contact" class="text-gray-400 hover:text-white transition">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-lg mb-4">Services</h4>
                    <ul class="space-y-2">
                        <li><a href="#" class="text-gray-400 hover:text-white transition">Bottle Advertising</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition">Kiosk Display</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition">QR Campaigns</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition">Analytics</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition">Enterprise</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-lg mb-4">Connect</h4>
                    <div class="flex space-x-4 mb-4">
                        <a href="#" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gray-700 transition"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gray-700 transition"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gray-700 transition"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gray-700 transition"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                    <p class="text-gray-400 text-sm">contact@adquench.com</p>
                    <p class="text-gray-400 text-sm">1-800-ADQUENCH</p>
                </div>
            </div>
            <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center">
                <p class="text-gray-400 text-sm">2024 AdQuench. All rights reserved.</p>
                <div class="flex space-x-6 mt-4 md:mt-0">
                    <a href="#" class="text-gray-400 hover:text-white text-sm">Privacy Policy</a>
                    <a href="#" class="text-gray-400 hover:text-white text-sm">Terms of Service</a>
                    <a href="#" class="text-gray-400 hover:text-white text-sm">Cookie Policy</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Success Modal -->
    <div id="successModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-8 max-w-md mx-4 text-center">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4"><i class="fas fa-check text-green-600 text-2xl"></i></div>
            <h3 class="text-2xl font-bold text-gray-800 mb-2">Message Sent!</h3>
            <p class="text-gray-600 mb-6">Thank you for reaching out. We'll get back to you within 24 hours.</p>
            <button onclick="document.getElementById('successModal').classList.add('hidden'); document.getElementById('successModal').classList.remove('flex');" class="btn-primary text-white px-8 py-3 rounded-lg font-semibold">Got it!</button>
        </div>
    </div>

    <script>
        document.getElementById('mobile-menu-btn').addEventListener('click', () => {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    document.getElementById('mobile-menu').classList.add('hidden');
                }
            });
        });
        document.getElementById('customerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            document.getElementById('successModal').classList.remove('hidden');
            document.getElementById('successModal').classList.add('flex');
            this.reset();
        });
        document.getElementById('advertiserForm').addEventListener('submit', function(e) {
            e.preventDefault();
            document.getElementById('successModal').classList.remove('hidden');
            document.getElementById('successModal').classList.add('flex');
            this.reset();
        });
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            if (window.scrollY > 50) nav.classList.add('shadow-md');
            else nav.classList.remove('shadow-md');
        });
    </script>
</body>
</html>
